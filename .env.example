# ─────────────────────────────────────────────────────────────────
# Copy this to .env.local for local dev
# Set as Vercel Environment Variables for production
# ─────────────────────────────────────────────────────────────────

# Full URL to your PHP api-stats.php on your server
VITE_API_URL=https://system.imperialvillapropertydevelopment.com/api/api-stats.php

# Stats re-fetch interval in milliseconds (default 60s)
VITE_POLL_INTERVAL=60000

# How often the video popup appears in milliseconds (default 5 min)
VITE_VIDEO_EVERY=300000

# How long the video popup plays before auto-closing in ms (default 2.5 min)
VITE_VIDEO_DURATION=150000
